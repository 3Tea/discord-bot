---
/**
 * Shared wrapper for legal pages (privacy, terms). Typography is styled via
 * global `.legal-page` / `.legal-prose` in global.css for consistency.
 */
interface Props {
  title: string;
  lastUpdated: string;
  lastUpdatedLabel?: string;
}

const { title, lastUpdated, lastUpdatedLabel = "Last updated" } = Astro.props;
---

<article class="legal-page container">
  <header class="legal-header">
    <h1 class="legal-title">{title}</h1>
    <p class="legal-meta">{lastUpdatedLabel}: {lastUpdated}</p>
  </header>
  <div class="legal-prose">
    <slot />
  </div>
</article>
