---
import { languages, defaultLang } from "../i18n/ui";
import { getLangFromUrl } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const currentLang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const pathname = Astro.url.pathname;

// Strip current locale prefix to get the base path
function getBasePath(path: string): string {
  for (const lang of Object.keys(languages)) {
    if (path === `/${lang}` || path === `/${lang}/`) return "/";
    if (path.startsWith(`/${lang}/`)) return path.slice(lang.length + 1);
  }
  return path;
}

const basePath = getBasePath(pathname);

// Content detail pages ([lang]/guide/slug, [lang]/commands/slug) always need lang prefix
const isDetailPage = basePath.startsWith("/guide/") || basePath.startsWith("/commands/");

function buildHref(lang: string): string {
  if (isDetailPage) return `/${lang}${basePath}`;
  if (lang === defaultLang) return basePath;
  return `/${lang}${basePath === "/" ? "" : basePath}`;
}
---

<div class="lang-switcher">
  {Object.entries(languages).map(([code, label]) => (
    <a
      href={buildHref(code)}
      class:list={["lang-btn", { active: currentLang === code }]}
      aria-label={`Switch to ${label}`}
    >
      {code.toUpperCase()}
    </a>
  ))}
</div>

<style>
  .lang-switcher {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .lang-btn {
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    transition: color 0.2s, background 0.2s;
    text-decoration: none;
  }

  .lang-btn:hover {
    color: var(--text-primary);
    background: var(--accent-soft);
  }

  .lang-btn.active {
    color: var(--accent);
    background: rgba(88, 101, 242, 0.15);
  }
</style>
