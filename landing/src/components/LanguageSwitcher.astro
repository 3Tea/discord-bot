---
interface Props {
  currentLang: string;
  slug: string;
  basePath?: string;
}

const { currentLang, slug, basePath = "commands" } = Astro.props;

const languages = [
  { code: "en", label: "EN" },
  { code: "vi", label: "VI" },
];
---

<div class="lang-switcher">
  {languages.map((lang) => (
    <a
      href={`/${lang.code}/${basePath}/${slug}`}
      class:list={["lang-btn", { active: currentLang === lang.code }]}
      aria-label={`Switch to ${lang.label}`}
    >
      {lang.label}
    </a>
  ))}
</div>
