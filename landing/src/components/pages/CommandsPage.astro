---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CommandsSidebar from "../CommandsSidebar.astro";
import CommandCard from "../CommandCard.astro";
import { commands } from "../../data/commands";
import { useTranslations, useTranslatedPath } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const hreflang = [
  { lang: "en", href: "/commands" },
  { lang: "vi", href: "/vi/commands" },
];
---

<BaseLayout title={`${t("commands.title")} | 3AT - Endless Paradox`} lang={lang} hreflang={hreflang}>
  <div class="commands-page">
    <CommandsSidebar lang={lang} />

    <div class="commands-main">
      <div class="commands-header">
        <h1 class="commands-title">{t("commands.title")}</h1>
        <p class="commands-count">
          <span id="commands-count">{commands.length}</span> {t("commands.available")}
        </p>
      </div>

      <div class="commands-search-panel">
        <p class="commands-search-label">{t("commands.search.label")}</p>
        <div class="commands-search-wrap">
          <input
            type="text"
            class="commands-search"
            placeholder={`🔍 ${t("commands.search")}`}
            id="command-search"
          />
          <button
            type="button"
            class="search-clear"
            id="command-search-clear"
            aria-label={t("commands.search.clear")}
          >
            ×
          </button>
        </div>
        <p class="commands-search-hint">{t("commands.search.hint")}</p>
      </div>

      <div class="commands-grid" id="commands-grid">
        {commands.map((cmd) => (
          <div class="command-item" data-category={cmd.category} data-name={cmd.name} data-desc={cmd.description}>
            <CommandCard command={cmd} href={`/${lang}/commands/${cmd.name}`} lang={lang} />
          </div>
        ))}
      </div>
      <p id="commands-empty" class="commands-empty" hidden>{t("commands.search.empty")}</p>
    </div>
  </div>
</BaseLayout>

<style>
  .commands-page {
    display: flex;
    min-height: calc(100vh - 56px);
  }

  .commands-main {
    flex: 1;
    padding: 24px;
  }

  .commands-header {
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .commands-title {
    font-family: var(--font-display);
    color: var(--text-primary);
    font-size: clamp(1.35rem, 3vw, 1.65rem);
    font-weight: 700;
    margin-bottom: 4px;
    letter-spacing: -0.02em;
  }

  .commands-count {
    color: var(--text-muted);
    font-size: 13px;
  }

  .commands-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .commands-search-panel {
    margin-bottom: 16px;
  }

  .commands-search-label {
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }

  .commands-search-wrap {
    position: relative;
    max-width: 440px;
  }

  .commands-search {
    width: 100%;
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 10px 36px 10px 12px;
    color: var(--text-primary);
    font-size: 14px;
    font-family: inherit;
    outline: none;
  }

  .commands-search::placeholder {
    color: var(--text-muted);
  }

  .commands-search:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(88, 101, 242, 0.2);
  }

  .commands-search-hint {
    margin-top: 6px;
    color: var(--text-muted);
    font-size: 11px;
  }

  .search-clear {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    border: none;
    background: transparent;
    color: var(--text-muted);
    width: 20px;
    height: 20px;
    border-radius: 999px;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    line-height: 1;
  }

  .search-clear:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.08);
  }

  .search-clear.visible {
    display: inline-flex;
  }

  .command-item {
    height: 100%;
  }

  .commands-empty {
    margin-top: 16px;
    color: var(--text-muted);
    font-size: 13px;
  }

  @media (max-width: 768px) {
    .commands-page {
      flex-direction: column;
    }

    .commands-grid {
      grid-template-columns: 1fr;
    }

    .commands-search-wrap {
      max-width: 100%;
    }
  }
</style>

<script>
  const sidebar = document.getElementById("commands-sidebar");
  const grid = document.getElementById("commands-grid");
  const searchInput = document.getElementById("command-search") as HTMLInputElement | null;
  const searchClear = document.getElementById("command-search-clear") as HTMLButtonElement | null;
  const countEl = document.getElementById("commands-count");
  const emptyEl = document.getElementById("commands-empty");
  const titleEl = document.querySelector(".commands-title");
  const cards = grid ? Array.from(grid.children) as HTMLElement[] : [];

  let activeCategory = "all";

  function filterCards(): void {
    const query = searchInput?.value.toLowerCase() || "";
    let visible = 0;

    cards.forEach((card) => {
      const cat = card.dataset.category || "";
      const name = card.dataset.name || "";
      const desc = card.dataset.desc || "";

      const matchCategory = activeCategory === "all" || cat === activeCategory;
      const matchSearch =
        !query || name.includes(query) || desc.toLowerCase().includes(query);

      const show = matchCategory && matchSearch;
      card.style.display = show ? "" : "none";
      if (show) visible++;
    });

    if (countEl) countEl.textContent = String(visible);
    if (emptyEl) emptyEl.hidden = visible !== 0;
    if (searchClear) searchClear.classList.toggle("visible", Boolean(searchInput?.value));
  }

  sidebar?.querySelectorAll("[data-category]").forEach((btn) => {
    btn.addEventListener("click", () => {
      sidebar.querySelectorAll("[data-category]").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeCategory = (btn as HTMLElement).dataset.category || "all";

      const label = (btn as HTMLElement).dataset.title || btn.textContent?.trim() || "Commands";
      if (titleEl) titleEl.textContent = label;

      filterCards();
    });
  });

  let debounceTimer: ReturnType<typeof setTimeout>;
  searchInput?.addEventListener("input", () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(filterCards, 200);
  });

  searchClear?.addEventListener("click", () => {
    if (!searchInput) return;
    searchInput.value = "";
    searchInput.focus();
    filterCards();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "/" || !searchInput) return;
    const target = event.target;
    if (
      target instanceof HTMLInputElement ||
      target instanceof HTMLTextAreaElement ||
      target instanceof HTMLSelectElement ||
      (target instanceof HTMLElement && target.isContentEditable)
    ) {
      return;
    }
    event.preventDefault();
    searchInput.focus();
  });

  filterCards();
</script>
