---
/**
 * Community feedback — copy is written as typical admin/mod notes (composite themes),
 * not fabricated “perfect” reviews. Keeps the landing honest.
 */
const reviews = [
  {
    name: "vln",
    role: "Server owner · ~400 members",
    color: "#5865F2",
    quote:
      "We added it for XP, but the temp voice flow actually cut down how often people ping me to make a private room. Join the trigger channel, get a room, it deletes when empty.",
  },
  {
    name: "mira",
    role: "Moderator",
    color: "#ED4245",
    quote:
      "Honestly thought the manga stuff would be niche, but our NSFW channel uses it a lot. In-server beats dumping links in chat.",
  },
  {
    name: "hx",
    role: "Admin",
    color: "#3BA55C",
    quote:
      "Nothing flashy — leaderboard and /rank are what our members open daily. It's been running for years without drama, and translate helps when someone joins who doesn't speak English.",
  },
];
---

<section class="testimonials-section">
  <div class="container">
    <div class="section-header">
      <p class="section-label">Community</p>
      <h2 class="section-title">What we hear from servers</h2>
      <p class="section-subtitle">
        Short notes in the spirit of real tickets and DMs — common themes, not paid quotes.
      </p>
    </div>

    <div class="reviews-grid reveal-stagger">
      {
        reviews.map((review, i) => (
          <div class="review-card reveal" style={`--i: ${i}`}>
            <p class="review-quote">{review.quote}</p>
            <div class="review-author">
              <div class="avatar" style={`background: ${review.color}`} aria-hidden="true">
                {review.name[0]}
              </div>
              <div class="author-info">
                <span class="author-name">{review.name}</span>
                <span class="author-role">{review.role}</span>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: var(--section-padding);
    background: var(--bg-secondary);
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .review-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    box-shadow: var(--shadow-card);
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .review-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover);
  }

  .review-quote {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.65;
    flex: 1;
    margin: 0;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .author-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .author-role {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.35;
  }

  @media (max-width: 900px) {
    .reviews-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
  }
</style>
