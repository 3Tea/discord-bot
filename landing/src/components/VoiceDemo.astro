---
const steps = [
  {
    number: 1,
    title: "Join the trigger channel",
    desc: 'Any channel with a "3AT " prefix acts as a trigger. Just join it.',
  },
  {
    number: 2,
    title: "Bot auto-creates your room",
    desc: "A private voice channel is instantly created just for you.",
  },
  {
    number: 3,
    title: "Use the control panel",
    desc: "Lock, hide, permit, kick, rename — full control via slash commands.",
  },
  {
    number: 4,
    title: "Auto-cleanup when empty",
    desc: "When everyone leaves, the channel is deleted automatically.",
  },
];

const controlButtons = [
  { label: "Lock", active: true },
  { label: "Unlock", active: false },
  { label: "Hide", active: false },
  { label: "Show", active: false },
  { label: "Permit", active: false },
  { label: "Kick", active: false },
  { label: "Transfer", active: false },
  { label: "Rename", active: false },
];
---

<section id="voice" class="voice-section">
  <div class="container">
    <div class="section-header">
      <p class="section-label">Voice Management</p>
      <h2 class="section-title">Your room, your rules</h2>
      <p class="section-subtitle">
        Temporary voice channels that create themselves and clean up after.
      </p>
    </div>

    <div class="voice-grid">
      <!-- Steps -->
      <div class="voice-steps reveal">
        {
          steps.map((step) => (
            <div class="step">
              <div class="step-circle">{step.number}</div>
              <div class="step-content">
                <h3 class="step-title">{step.title}</h3>
                <p class="step-desc">{step.desc}</p>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Discord Sidebar Mockup -->
      <div class="discord-mockup reveal" style="--i: 1">
        <div class="sidebar-header">
          <span class="server-name">🎮 My Server</span>
        </div>
        <div class="sidebar-body">
          <div class="channel-category">Voice Channels</div>

          <!-- Trigger channel -->
          <div class="channel-item muted">
            <svg class="ch-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
            </svg>
            3AT Create Room
          </div>

          <!-- Active: Jake's Room -->
          <div class="channel-item active">
            <svg class="ch-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
            </svg>
            Jake's Room
            <svg class="lock-icon" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/>
            </svg>
            <div class="channel-users">
              <div class="user-row">
                <div class="user-avatar" style="background: #5865F2;">J</div>
                <span class="user-name">Jake</span>
              </div>
              <div class="user-row">
                <div class="user-avatar" style="background: #ED4245;">A</div>
                <span class="user-name">Alice</span>
              </div>
            </div>
          </div>

          <!-- Tea's Room -->
          <div class="channel-item">
            <svg class="ch-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
            </svg>
            Tea's Room
            <div class="channel-users">
              <div class="user-row">
                <div class="user-avatar" style="background: #3BA55C;">T</div>
                <span class="user-name">Tea</span>
              </div>
              <div class="user-row">
                <div class="user-avatar" style="background: #FAA61A;">B</div>
                <span class="user-name">Bob</span>
              </div>
            </div>
          </div>

          <!-- Control panel -->
          <div class="control-panel">
            <div class="panel-label">Control Panel</div>
            <div class="panel-buttons">
              {
                controlButtons.map((btn) => (
                  <button class={`panel-btn ${btn.active ? "active" : ""}`}>{btn.label}</button>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .voice-section {
    padding: var(--section-padding);
    background: var(--bg-secondary);
  }

  .voice-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  /* Steps */
  .voice-steps {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .step-circle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-title {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
    letter-spacing: -0.02em;
  }

  .step-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* Discord Mockup */
  .discord-mockup {
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    font-size: 13px;
    box-shadow: var(--shadow-card);
  }

  .sidebar-header {
    background: #1a1b1e;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
  }

  .server-name {
    color: var(--text-primary);
    font-weight: 600;
    font-size: 14px;
  }

  .sidebar-body {
    padding: 8px 0;
  }

  .channel-category {
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding: 8px 16px 4px;
  }

  .channel-item {
    display: flex;
    flex-direction: column;
    padding: 4px 8px 4px 16px;
    border-radius: 4px;
    margin: 1px 8px;
    color: var(--text-secondary);
    cursor: default;
    gap: 4px;
  }

  .channel-item > .ch-icon,
  .channel-item > span:first-of-type {
    display: inline;
  }

  /* Use a flex row for the first line of each channel item */
  .channel-item {
    position: relative;
  }

  .ch-icon {
    display: inline;
    vertical-align: middle;
    margin-right: 4px;
    color: var(--text-muted);
  }

  .lock-icon {
    display: inline;
    vertical-align: middle;
    margin-left: 4px;
    color: var(--text-muted);
  }

  .channel-item.muted {
    color: var(--text-muted);
  }

  .channel-item.active {
    background: rgba(88, 101, 242, 0.2);
    color: var(--text-primary);
  }

  .channel-users {
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 2px;
  }

  .user-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .user-avatar {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    font-size: 9px;
    font-weight: 700;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .user-name {
    color: var(--text-secondary);
    font-size: 12px;
  }

  /* Control panel */
  .control-panel {
    margin: 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
  }

  .panel-label {
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-bottom: 8px;
  }

  .panel-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .panel-btn {
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    color: var(--text-secondary);
    font-size: 12px;
    cursor: default;
    transition: none;
  }

  .panel-btn.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  @media (max-width: 768px) {
    .voice-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .discord-mockup {
      order: -1;
    }
  }
</style>
