---
import { useTranslations, useTranslatedPath } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);

const inviteUrl =
  "https://discord.com/api/oauth2/authorize?client_id=615052741911379983&permissions=8&scope=applications.commands%20bot";
---

<section class="hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="hero-noise" aria-hidden="true"></div>
  <div class="hero-content">
    <img
      src="/maid2.gif"
      alt="3AT Bot Logo"
      class="hero-logo"
      width="96"
      height="96"
    />
    <h1 class="hero-title">3AT — Endless Paradox</h1>
    <p class="hero-subtitle">
      {t("hero.subtitle")}
    </p>
    <div class="hero-buttons">
      <a href={inviteUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        <svg width="16" height="12" viewBox="0 0 71 55" fill="white" aria-hidden="true">
          <path d="M60.1 4.9A58.5 58.5 0 0045.7.2a.2.2 0 00-.2.1 40.8 40.8 0 00-1.8 3.7 54 54 0 00-16.2 0A37.4 37.4 0 0025.6.3a.2.2 0 00-.2-.1A58.4 58.4 0 0011 4.9a.2.2 0 00-.1.1C1.6 18.4-.9 31.5.3 44.5v.1a58.7 58.7 0 0017.9 9.1.2.2 0 00.3-.1 42 42 0 003.6-5.9.2.2 0 00-.1-.3 38.6 38.6 0 01-5.5-2.6.2.2 0 010-.4l1.1-.9a.2.2 0 01.2 0 41.9 41.9 0 0035.6 0 .2.2 0 01.2 0l1.1.9a.2.2 0 010 .4c-1.8 1-3.6 1.8-5.5 2.6a.2.2 0 00-.1.3 47.2 47.2 0 003.6 5.9.2.2 0 00.3.1A58.5 58.5 0 0070.8 44.6v-.1c1.4-15-2.3-28-9.8-39.5a.2.2 0 00-.1-.1zM23.7 36.5c-3.4 0-6.2-3.1-6.2-7s2.7-7 6.2-7 6.3 3.2 6.2 7-2.8 7-6.2 7zm23 0c-3.4 0-6.2-3.1-6.2-7s2.7-7 6.2-7 6.3 3.2 6.2 7-2.7 7-6.2 7z"/>
        </svg>
        {t("hero.add")}
      </a>
      <a href={tp("/#commands")} class="btn btn-secondary">{t("hero.commands")}</a>
    </div>
    <p class="hero-trust">
      {t("hero.trust")}
    </p>
  </div>
  <a href="#features" class="hero-scroll" aria-label={t("hero.scroll")}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </a>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: var(--bg-primary);
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -60%);
    width: 560px;
    height: 560px;
    border-radius: 50%;
    background:
      radial-gradient(circle at 35% 42%, rgba(88, 101, 242, 0.22) 0%, transparent 48%),
      radial-gradient(circle at 68% 48%, rgba(155, 89, 182, 0.1) 0%, transparent 52%),
      radial-gradient(circle, rgba(88, 101, 242, 0.08) 0%, transparent 72%);
    animation: glow-pulse 4s ease-in-out infinite;
    pointer-events: none;
  }

  /* Subtle film grain so the hero feels less flat without heavy assets */
  .hero-noise {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    padding: 0 24px;
    max-width: 640px;
  }

  .hero-logo {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 3px solid var(--accent);
    box-shadow: 0 0 24px rgba(88, 101, 242, 0.4);
    object-fit: cover;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5.5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  @supports (background-clip: text) or (-webkit-background-clip: text) {
    .hero-title {
      background: linear-gradient(135deg, #f8f9fc 0%, #e4e7ff 45%, #b5bac1 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
  }

  .hero-subtitle {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 520px;
  }

  .hero-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: var(--radius-md);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
    text-decoration: none;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    box-shadow: 0 4px 16px rgba(88, 101, 242, 0.35);
  }

  .btn-primary:focus-visible {
    outline: 2px solid var(--text-primary);
    outline-offset: 2px;
  }

  .btn-secondary {
    background: #4E5058;
    color: var(--text-primary);
  }

  .btn-secondary:hover {
    background: rgba(88, 101, 242, 0.5);
  }

  .hero-trust {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--text-muted);
    animation: bounce 2s ease-in-out infinite;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
  }

  .hero-scroll:hover {
    color: var(--accent);
  }

  @media (max-width: 600px) {
    .hero-subtitle {
      font-size: 15px;
    }
  }
</style>
