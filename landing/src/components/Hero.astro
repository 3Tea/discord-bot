---
const inviteUrl =
  "https://discord.com/api/oauth2/authorize?client_id=615052741911379983&permissions=8&scope=applications.commands%20bot";
---

<section class="hero">
  <div class="hero-glow"></div>
  <div class="hero-content">
    <img
      src="/maid2.gif"
      alt="3AT Bot Logo"
      class="hero-logo"
      width="96"
      height="96"
    />
    <h1 class="hero-title">3AT — Endless Paradox</h1>
    <p class="hero-subtitle">
      A Discord bot packed with voice management, manga reader, translation,
      weather — and more. Slash commands only, always up.
    </p>
    <div class="hero-buttons">
      <a href={inviteUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        <svg width="16" height="12" viewBox="0 0 71 55" fill="white" aria-hidden="true">
          <path d="M60.1 4.9A58.5 58.5 0 0045.7.2a.2.2 0 00-.2.1 40.8 40.8 0 00-1.8 3.7 54 54 0 00-16.2 0A37.4 37.4 0 0025.6.3a.2.2 0 00-.2-.1A58.4 58.4 0 0011 4.9a.2.2 0 00-.1.1C1.6 18.4-.9 31.5.3 44.5v.1a58.7 58.7 0 0017.9 9.1.2.2 0 00.3-.1 42 42 0 003.6-5.9.2.2 0 00-.1-.3 38.6 38.6 0 01-5.5-2.6.2.2 0 010-.4l1.1-.9a.2.2 0 01.2 0 41.9 41.9 0 0035.6 0 .2.2 0 01.2 0l1.1.9a.2.2 0 010 .4c-1.8 1-3.6 1.8-5.5 2.6a.2.2 0 00-.1.3 47.2 47.2 0 003.6 5.9.2.2 0 00.3.1A58.5 58.5 0 0070.8 44.6v-.1c1.4-15-2.3-28-9.8-39.5a.2.2 0 00-.1-.1zM23.7 36.5c-3.4 0-6.2-3.1-6.2-7s2.7-7 6.2-7 6.3 3.2 6.2 7-2.8 7-6.2 7zm23 0c-3.4 0-6.2-3.1-6.2-7s2.7-7 6.2-7 6.3 3.2 6.2 7-2.7 7-6.2 7z"/>
        </svg>
        Add to Server
      </a>
      <a href="#commands" class="btn btn-secondary">View Commands</a>
    </div>
    <p class="hero-trust">
      Free to use &middot; Slash commands &middot; Online since 2019
    </p>
  </div>
  <a href="#features" class="hero-scroll" aria-label="Scroll to features">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </a>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: var(--bg-primary);
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -60%);
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(88, 101, 242, 0.15) 0%, transparent 70%);
    animation: glow-pulse 4s ease-in-out infinite;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    padding: 0 24px;
    max-width: 640px;
  }

  .hero-logo {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 3px solid var(--accent);
    box-shadow: 0 0 24px rgba(88, 101, 242, 0.4);
    object-fit: cover;
  }

  .hero-title {
    font-size: 42px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
    margin: 0;
  }

  .hero-subtitle {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 520px;
  }

  .hero-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: var(--radius-md);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
    text-decoration: none;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--accent-hover);
  }

  .btn-secondary {
    background: #4E5058;
    color: var(--text-primary);
  }

  .btn-secondary:hover {
    background: rgba(88, 101, 242, 0.5);
  }

  .hero-trust {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--text-muted);
    animation: bounce 2s ease-in-out infinite;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
  }

  .hero-scroll:hover {
    color: var(--accent);
  }

  @media (max-width: 600px) {
    .hero-title {
      font-size: 30px;
    }

    .hero-subtitle {
      font-size: 15px;
    }
  }
</style>
